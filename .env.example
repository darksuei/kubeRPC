PORT=8080

CACHE_TYPE=memory # redis | memory

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Webhook server (Kubernetes-only — leave empty when running outside a cluster)
WEBHOOK_PORT=9443
KUBERPC_CORE_URL=http://kuberpc-core.kuberpc.svc.cluster.local:8080
TLS_CERT_PATH=/etc/kuberpc/tls/tls.crt
TLS_KEY_PATH=/etc/kuberpc/tls/tls.key
